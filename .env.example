# Supabase (Client-Base)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Partnerships - if different)
NEXT_PUBLIC_SUPABASE_PARTNERS_URL=
NEXT_PUBLIC_SUPABASE_PARTNERS_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_CLIENT_BASE=true
NEXT_PUBLIC_ENABLE_PARTNERSHIPS=true

# ─── Replicate API ────────────────────────────────────────────────────────────
# For FLUX/Kling video generation
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ─── Replicate Webhook ────────────────────────────────────────────────────────
REPLICATE_WEBHOOK_SECRET=

# ─── Notifications ───────────────────────────────────────────────────────────
# Telegram: create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Slack: create an incoming webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Drive folder ID for video delivery (from folder URL: drive.google.com/drive/folders/[THIS_PART])
GOOGLE_DRIVE_VIDEOS_ALL_FOLDER=
