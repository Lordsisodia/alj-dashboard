{
  "name": "siso-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Unified SISO platform - client-base & partnerships",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo",
    "dev:clean": "rm -rf .next && NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo",
    "clean": "rm -rf .next",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "predev": "node scripts/check-node.js",
    "prebuild": "node scripts/check-node.js",
    "prestart": "node scripts/check-node.js",
    "perf:hydration": "node scripts/perf/check-hydration-heuristics.mjs",
    "perf:baseline": "node scripts/perf/run-baseline.mjs",
    "perf:budgets": "node scripts/perf/check-bundle-budgets.mjs",
    "perf:media": "node scripts/perf/check-hero-media.mjs",
    "perf:tti": "node scripts/perf/check-tti.mjs",
    "perf:lighthouse-budgets": "node scripts/perf/check-lighthouse-budgets.mjs",
    "perf:lhci": "lhci autorun",
    "size": "size-limit",
    "start": "next start",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint .",
    "lint:warnings": "node scripts/check-lint-warnings.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "portfolio:export": "node scripts/portfolio/export-clients.cjs",
    "check:partners-structure": "node scripts/check-partnership-structure.mjs",
    "generate:partner-feature": "node scripts/generate-partner-feature.mjs",
    "check:nav-sync": "node scripts/check-nav-sync.mjs",
    "check:partners": "cross-env CHECK_MODE=strict node scripts/run-checks.mjs"
  },
