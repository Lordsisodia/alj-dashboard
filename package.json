    "@types/react": "^18.3.18",
    "@types/react-countup": "^4.3.1",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "eslint-plugin-no-portal-imports": "file:scripts/lint",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "puppeteer": "^24.15.0",
    "react-scan": "^0.5.3",
    "size-limit": "^12.0.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "web-vitals": "^5.1.0"
